{
  "name": "web-chat-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:url": "node scripts/print-dev-url.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "vite build --outDir ../static/dist",
    "lint": "npx --yes @biomejs/biome@2.3.8 ci .",
    "audit:unused": "npx --yes knip --include files,exports --reporter compact",
    "test": "vitest run",
    "lint:fix": "npx --yes @biomejs/biome@2.3.8 check --write .",
    "check": "npm run typecheck && npm run lint",
    "check:storybook": "npm run build-storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@go-go-golems/chat-provider": "file:../../../../2026-05-29--chatbot-overlay-glm/packages/chat-provider",
    "@reduxjs/toolkit": "^2.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-redux": "^9.2.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.15",
    "@storybook/addon-interactions": "8.6.15",
    "@storybook/react-vite": "8.6.15",
    "@storybook/test": "8.6.15",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "msw": "^2.7.0",
    "msw-storybook-addon": "^2.0.4",
    "storybook": "8.6.15",
    "typescript": "^5.7.3",
    "vite": "^5.4.19",
    "vitest": "^4.0.18"
  }
}
